# ============================================
# .env.example - Template Configuration
# ============================================
# 
# INSTRUCTIONS:
# 1. Copie ce fichier en ".env" dans le même répertoire
# 2. Remplis TOUTES les valeurs avec tes clés API réelles
# 3. JAMAIS commiter le ".env" réel (il est dans .gitignore)
# 4. Utilise .env.example pour documenter les variables nécessaires
#
# ============================================

# TELEGRAM BOT
# Récupère auprès de @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=999999999

# NOTION API
# Crée une intégration sur https://www.notion.com/my-integrations
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database IDs
# Récupère via: https://api.notion.com/v1/databases (avec token)
# Ou copie depuis l'URL Notion: notion.so/workspace/{DATABASE_ID}
NOTION_DATABASE_ID_TASKS=xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID_HEALTH=xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID_PROJECTS=xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID_OBJECTIVES=xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID_VICTORIES=xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID_FAMILY=xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID_CRM=xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID_REFLECTIONS=xxxxxxxxxxxxxxxxxxxxxxxx

# GOOGLE CALENDAR
# Crée un projet sur https://console.cloud.google.com
# Active Google Calendar API
# Crée OAuth2 credentials (Web Application)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSP-xxxxx
GOOGLE_REDIRECT_URI=http://localhost:5678/rest/oauth2-callback
GOOGLE_CALENDAR_ID=primary

# OPENROUTER (LLM - Leo)
# Crée un compte sur https://openrouter.ai
# API Keys → copie ta clé
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxx

# BREVO (Email - Optionnel)
# Crée un compte sur https://www.brevo.com
# Settings → SMTP & API → API keys
BREVO_API_KEY=xxxxxxxxxxx
BREVO_SENDER_EMAIL=leo.horizons.bot@gmail.com

# N8N CONFIG (Self-hosted)
# Seulement si tu déploies n8n en self-hosted
N8N_PROTOCOL=https
N8N_HOST=localhost:5678
N8N_ENCRYPTION_KEY=change-me-to-random-string-32chars
N8N_USER_MANAGEMENT_JWT_SECRET=change-me-to-random-string
WEBHOOK_TUNNEL_URL=https://ton-domaine.com/

# OPENCLAW / LEO CONFIG
# Configuration assistant IA
OPENCLAW_PORT=8000
OPENCLAW_LOG_LEVEL=info
OPENCLAW_SECRET_KEY=change-me-to-random-string-32chars
LEO_EMAIL=leo.horizons.bot@gmail.com

# N8N WEBHOOK BASE URL
# URL utilisée par OpenClaw pour appeler les webhooks n8n
N8N_WEBHOOK_BASE_URL=https://coaching.estarellas.online

# TIMEZONE & LOCALES
TIMEZONE=Europe/Paris
LOCALE=fr-FR

# ENVIRONMENT
# Valeurs: development, staging, production
NODE_ENV=development