# ============================================
# .env.example - Template Configuration
# ============================================
#
# INSTRUCTIONS:
# 1. Copie ce fichier en ".env" dans le même répertoire
# 2. Remplis TOUTES les valeurs avec tes clés API réelles
# 3. JAMAIS commiter le ".env" réel (il est dans .gitignore)
# 4. Utilise .env.example pour documenter les variables nécessaires
#
# ============================================
# NOTE: Sur le VPS, la config OpenClaw est dans ~/n8n-docker/openclaw-config/.env
# Ce fichier sert de RÉFÉRENCE pour toutes les variables du système.
# ============================================

# ---- OPENCLAW (.env dans ~/n8n-docker/openclaw-config/.env) ----

# TELEGRAM BOT
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_ALLOWED_USERS=999999999

# OPENROUTER (LLM)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxx
PRIMARY_MODEL=anthropic/claude-haiku-4-5
FALLBACK_MODEL=google/gemini-2.5-flash

# GOOGLE API (Gemini direct)
GOOGLE_API_KEY=AIzaSy-xxxxxxxxxxxxx

# NOTION API (à ajouter à OpenClaw .env)
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# N8N WEBHOOK BASE URL (à ajouter à OpenClaw .env)
N8N_WEBHOOK_BASE_URL=https://coaching.estarellas.online

# ---- N8N COACHING (env vars dans docker-compose.yml) ----

# Notion Database IDs (config réelle dans n8n-coaching)
NOTION_DB_TASKS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_PROJECTS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_SEASONS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_VICTOIRES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PAGE_HEALTH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PAGE_BUDGET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=999999999

# ---- GOOGLE CALENDAR (configuré dans n8n via credentials UI) ----

GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSP-xxxxx
GOOGLE_CALENDAR_ID=primary

# ---- URLS DU SYSTÈME ----

# OpenClaw (Leo)
LEO_URL=https://leo.estarellas.online
# n8n Coaching (webhooks)
N8N_COACHING_URL=https://coaching.estarellas.online
# Accès Tailscale
TAILSCALE_URL=https://vps-n8n-prod.tail179067.ts.net

# ---- GÉNÉRAL ----

TIMEZONE=Europe/Paris
LOCALE=fr-FR
NODE_ENV=production
