        "jsCode": "const ev = $input.first().json;\nreturn [{\n  json: {\n    success: true,\n    message: 'Événement créé avec succès',\n    eventId: ev.id || '',\n    eventLink: ev.htmlLink || '',\n    titre: ev.summary || '',\n    debut: ev.start?.dateTime || ''\n  }\n}];"
