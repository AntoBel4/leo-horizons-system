      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst titre = body.titre || 'Événement sans titre';\nconst debut = new Date(body.debut);\nconst duree = body.duree || 60;\nconst fin = new Date(debut.getTime() + duree * 60000);\n\nreturn [{\n  json: {\n    titre: titre,\n    debut: debut.toISOString(),\n    fin: fin.toISOString(),\n    colorId: String(body.colorId || '1'),\n    description: body.description || '',\n    calendarId: body.calendarId || 'primary'\n  }\n}];"
      },
      "id": "630b707b-ed77-4254-8020-cfa7c02ece00",
      "name": "Parse Input",
