        0
      ]
    },
    {
      "parameters": {
        "calendar": {
          "__rl": true,
          "value": "antoinestarellas@gmail.com",
          "mode": "list",
          "cachedResultName": "antoinestarellas@gmail.com"
        },
        "start": "={{ $json.debut }}",
        "end": "={{ $json.fin }}",
        "additionalFields": {
          "description": "={{ $json.description }}",
          "summary": "={{ $json.titre }}"
        }
      },
