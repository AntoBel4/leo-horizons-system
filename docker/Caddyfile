# ============================================
# Caddyfile — RÉFÉRENCE de la config reverse proxy VPS
# ============================================
# Ce fichier documente le Caddyfile réel du VPS.
# Pour modifier, éditer : ~/n8n-docker/Caddyfile
# ============================================

# n8n principal (immobilier)
n8n.rentrerdesmandats.fr {
    reverse_proxy n8n:5678
}

# n8n coaching (Leo workflows WF1-WF4)
coaching.estarellas.online {
    reverse_proxy n8n-coaching:5678
}

# OpenClaw (Leo assistant IA)
# Note: OpenClaw bind à 127.0.0.1 uniquement, socat proxy expose sur :18790
# Headers strippés pour éviter les conflits avec le proxy interne
leo.estarellas.online {
    reverse_proxy openclaw:18790 {
        header_up -X-Forwarded-For
        header_up -X-Forwarded-Proto
        header_up -X-Forwarded-Host
        header_up -X-Real-Ip
    }
}

# App prospect
app.estarellas.online {
    reverse_proxy prospect-app:8501
}

# n8n expert-local
prospect.estarellas.online {
    reverse_proxy n8n-expert-local:5678
}

# n8n automation
automation.estarellas.online {
    reverse_proxy n8n-automation:5678
}

# Accès Tailscale direct à OpenClaw
vps-n8n-prod.tail179067.ts.net {
    reverse_proxy 127.0.0.1:18789
}

