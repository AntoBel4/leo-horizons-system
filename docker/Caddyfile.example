# ============================================
# Caddyfile - Reverse Proxy pour Leo Horizons
# ============================================
#
# USAGE:
#   cp Caddyfile.example Caddyfile
#   Remplace "leo.estarellas.online" par ton domaine
#
# NOTE: Avec network_mode: host, tous les conteneurs partagent
# le réseau du VPS. On utilise donc 127.0.0.1 (pas un nom de service).
#
# ============================================

# Domaine principal - OpenClaw (Leo)
# NOTE: Caddy v2 gère automatiquement les WebSockets (upgrade Connection).
# On ajoute des timeouts plus longs pour les connexions WS longue durée.
leo.estarellas.online {
	reverse_proxy 127.0.0.1:18789 {
		# Timeouts pour les WebSockets (connexions longue durée)
		transport http {
			read_timeout 300s
			write_timeout 300s
		}

		# Health check pour détecter un crash-loop
		health_uri /
		health_interval 30s
		health_timeout 5s
	}
}

# Domaine n8n (optionnel - ajuster selon ton setup)
# n8n.estarellas.online {
# 	reverse_proxy 127.0.0.1:5678
# }
